# Postgres container credentials (compose uses these)
POSTGRES_DB=hexmaster
POSTGRES_USER=hexmaster
POSTGRES_PASSWORD=<POSTGRES_PASSWORD>

# Bot runtime
DISCORD_TOKEN=<DISCORD_BOT_TOKEN>

# App connects to Postgres via compose service name "postgres"
DATABASE_URL=postgresql+asyncpg://hexmaster:<POSTGRES_PASSWORD>@postgres:5432/hexmaster

# Point to the OCR service running on your host machine
OCR_URL=http://localhost:5000
WARAPI_BASE_URL="https://war-service-live.foxholeservices.com/api"